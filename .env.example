# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@wonderlandplayhouse.com

# Cal.com (discovery call embed)
NEXT_PUBLIC_CAL_LINK=wonderland-playhouse/discovery

# Site
NEXT_PUBLIC_SITE_URL=https://www.wonderlandplayhouse.com

# Analytics — Google Analytics 4. Set to the client's own Measurement ID
# (Admin → Data Streams → Web, looks like G-XXXXXXXXXX). Unset = no analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Owner notifications
OWNER_NOTIFY_EMAIL=info@wonderlandplayhouse.com
OWNER_NOTIFY_PHONE=+17188891777

# Chat assistant (Anthropic Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Google Calendar integration (OAuth web client — same Client ID used for admin sign-in)
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

# Twilio — inbound SMS AI auto-responder (DRAFT; inert until set + webhook configured)
# Point Twilio's "A message comes in" webhook at POST /api/sms/inbound.
# TWILIO_AUTH_TOKEN is required for the responder to run AND to verify requests
# really came from Twilio. Without it, /api/sms/inbound does nothing.
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Only needed later if/when we send SMS from the server (REST API), not for inbound:
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
