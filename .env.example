# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@wonderlandplayhouse.com

# Twilio (transactional SMS) — find these in the Twilio Console.
# ACCOUNT_SID + AUTH_TOKEN under Account Info; FROM_NUMBER is an SMS-enabled
# number you own, in E.164 format. Leave blank to disable SMS (it no-ops safely).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Cal.com (discovery call embed)
NEXT_PUBLIC_CAL_LINK=wonderland-playhouse/discovery

# Site
NEXT_PUBLIC_SITE_URL=https://www.wonderlandplayhouse.com

# Owner notifications
OWNER_NOTIFY_EMAIL=info@wonderlandplayhouse.com
OWNER_NOTIFY_PHONE=+17188891777
